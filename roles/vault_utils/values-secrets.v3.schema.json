{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/valuesSecretsV3",
  "meta:license": [
    "Copyright 2022 Red Hat, Inc. All rights reserved.",
    "This file is licensed to you under the Apache License, Version 2.0 (the 'License');",
    "you may not use this file except in compliance with the License. You may obtain a copy",
    "of the License at http://www.apache.org/licenses/LICENSE-2.0"
  ],
  "title": "Validated Patterns - values-secret.yaml files schema V3",
  "description": "This schema defines the values-secret.yaml file as used by [Validated Patterns](https://validatedpatterns.io) version 3.0",
  "type": "object",
  "examples": [
    {
      "version": "3.0",
      "settings": {
        "targets": ["hub", "spoke1"],
        "namespace": "validated-patterns-secrets"
      },
      "policies": {
        "basic": {
          "length": 16,
          "charset": "alphanumeric"
        },
        "medium": {
          "length": 20,
          "charset": "alphanumeric_symbols"
        },
        "strong": {
          "length": 32,
          "charset": "all"
        },
        "custom": "length=10\nrule \"charset\" { charset = \"abcdefghijklmnopqrstuvwxyz\" min-chars = 1 }\n"
      },
      "secrets": {
        "database": {
          "username": "dbuser",
          "password": "generate:strong",
          "ca_cert": "file://path/to/ca.crt",
          "binary_file": "file+base64://path/to/binary.p12"
        },
        "api-config": {
          "targets": ["spoke1"],
          "endpoint": "https://api.example.com",
          "token": "generate:medium",
          "user_cert": "file+base64://path/to/user.crt"
        }
      }
    }
  ],
  "definitions": {
    "valuesSecretsV3": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Version of the secret specification",
          "const": "3.0"
        },
        "settings": {
          "$ref": "#/definitions/Settings",
          "description": "Global settings for the secrets configuration"
        },
        "policies": {
          "$ref": "#/definitions/Policies",
          "description": "Password generation policies for vault"
        },
        "secrets": {
          "$ref": "#/definitions/Secrets",
          "description": "The dictionary of secrets to be uploaded"
        }
      },
      "required": [
        "version",
        "secrets"
      ],
      "title": "Values Secrets V3 Format"
    },
    "Settings": {
      "type": "object",
      "description": "Global settings for the secrets configuration",
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "array",
          "description": "Default target prefixes for secrets",
          "items": {
            "type": "string"
          },
          "default": ["hub"]
        },
        "namespace": {
          "type": "string",
          "description": "Namespace for kubernetes secrets",
          "default": "validated-patterns-secrets"
        }
      }
    },
    "Policies": {
      "type": "object",
      "description": "Password generation policies",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/SimplifiedPolicy"
          },
          {
            "type": "string",
            "description": "Raw vault policy format"
          }
        ]
      }
    },
    "SimplifiedPolicy": {
      "type": "object",
      "description": "Simplified policy configuration",
      "additionalProperties": false,
      "properties": {
        "length": {
          "type": "integer",
          "description": "Password length",
          "minimum": 1,
          "default": 16
        },
        "charset": {
          "type": "string",
          "description": "Character set to use",
          "enum": ["alphanumeric", "alphanumeric_symbols", "all"],
          "default": "alphanumeric"
        }
      }
    },
    "Secrets": {
      "type": "object",
      "description": "Dictionary of secrets to be uploaded",
      "additionalProperties": {
        "$ref": "#/definitions/Secret"
      }
    },
    "Secret": {
      "type": "object",
      "description": "A single secret configuration",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/FieldInstruction"
          },
          {
            "type": "array",
            "description": "Target list for this secret",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "properties": {
        "targets": {
          "type": "array",
          "description": "Target prefixes for this secret",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "FieldInstruction": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^file://.*",
          "description": "File path instruction: file://path/to/file"
        },
        {
          "type": "string",
          "pattern": "^file\\+base64://.*",
          "description": "Base64-encoded file instruction: file+base64://path/to/file"
        },
        {
          "type": "string",
          "pattern": "^generate:.*",
          "description": "Password generation instruction: generate:policy_name"
        },
        {
          "type": "string",
          "pattern": "^prompt:.*",
          "description": "User prompt instruction: prompt:message"
        },
        {
          "type": "string",
          "description": "Static value"
        },
        {
          "type": "number",
          "description": "Static numeric value"
        },
        {
          "type": "boolean",
          "description": "Static boolean value"
        }
      ]
    }
  }
}