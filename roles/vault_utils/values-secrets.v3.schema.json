    "you may not use this file except in compliance with the License. You may obtain a copy",
    "of the License at http://www.apache.org/licenses/LICENSE-2.0"
  ],
  "title": "Validated Patterns - values-secret.yaml files schema V3",
  "description": "This schema defines the values-secret.yaml file as used by [Validated Patterns](https://validatedpatterns.io) version 3.0",
  "type": "object",
  "examples": [
    {
      "version": "3.0",
      "backingStore": "vault",
      "settings": {
        "targets": ["hub", "spoke1"],
        "namespace": "validated-patterns-secrets"
      },
      "policies": {
        "basic": {
          "length": 16,
          "charset": "alphanumeric"
        },
        "medium": {
          "length": 20,
          "charset": "alphanumeric_symbols"
        },
        "strong": {
          "length": 32,
          "charset": "all"
        },
        "custom": "length=10\nrule \"charset\" { charset = \"abcdefghijklmnopqrstuvwxyz\" min-chars = 1 }\n"
      },
      "secrets": {
        "database": {
          "username": "dbuser",
          "password": "generate:strong",
          "ca_cert": "file://path/to/ca.crt",
          "binary_file": "file+base64://path/to/binary.p12"
        },
        "api-config": {
          "targets": ["spoke1"],
          "endpoint": "https://api.example.com",
          "token": "generate:medium",
          "user_cert": "file+base64://path/to/user.crt"
        },
        "aws": {
          "access_key": "ini://~/.aws/credentials:default:aws_access_key_id",
          "secret_key": "ini://~/.aws/credentials:default:aws_secret_access_key",
          "region": "ini://~/.aws/config:region"
        }
      }
    },
    {
      "version": "3.0",
      "backingStore": "kubernetes",
      "settings": {
        "namespace": "validated-patterns-secrets"
      },
      "secrets": {
        "database": {
          "namespaces": "app-namespace",
          "type": "Opaque",
          "labels": {
            "environment": "production",
            "component": "database"
          },
          "annotations": {
            "database.io/connection-pool": "enabled"
          },
          "username": "dbuser",
          "password": "prompt:Enter database password",
          "ca_cert": "file://path/to/ca.crt"
        },
        "docker-registry": {
          "namespaces": ["default", "app1", "app2"],
          "type": "kubernetes.io/dockerconfigjson",
          "labels": {
            "registry": "production"
          },
          ".dockerconfigjson": "file+base64://~/.docker/config.json"
        },
        "tls-wildcard": {
          "namespaces": ["ingress-nginx", "istio-system"],
          "type": "kubernetes.io/tls",
          "labels": {
            "cert-type": "wildcard"
          },
          "tls.crt": "file://path/to/wildcard.crt",
          "tls.key": "file://path/to/wildcard.key"
        }
      }
    },
    {
      "version": "3.0",
      "backingStore": "aws-secrets-manager",
      "awsConfig": {
        "region": "us-east-1",
        "profile": "default",
        "prefix": "myapp/prod/",
        "defaultKmsKeyId": "alias/aws/secretsmanager",
        "defaultTags": {
          "Environment": "production",
          "ManagedBy": "validated-patterns"
        }
      },
      "secrets": {
        "database": {
          "secretName": "rds/credentials",
          "description": "Database credentials for production app",
          "tags": {
            "Application": "myapp",
            "Component": "database"
          },
          "username": "dbuser",
          "password": "prompt:Enter database password",
          "host": "ini://~/.config/db.ini:default:host"
        },
        "api-config": {
          "description": "API configuration and tokens",
          "tags": {
            "Application": "myapp",
            "Component": "api"
          },
          "endpoint": "https://api.example.com",
          "token": "prompt:Enter API token"
        },
        "tls-certificates": {
          "secretName": "certificates/wildcard-tls",
          "description": "Wildcard TLS certificate",
          "tls_crt": "file://path/to/wildcard.crt",
          "tls_key": "file://path/to/wildcard.key"
        }
      }
    }
  ],
  "definitions": {
    "valuesSecretsV3": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Version of the secret specification",
          "const": "3.0"
        },
        "backingStore": {
          "type": "string",
          "description": "Secrets backing store type",
          "default": "vault",
          "enum": ["vault", "kubernetes", "aws-secrets-manager"]
        },
        "settings": {
          "$ref": "#/definitions/Settings",
          "description": "Global settings for the secrets configuration"
        },
        "policies": {
          "$ref": "#/definitions/Policies",
          "description": "Password generation policies for vault"
        },
        "awsConfig": {
          "$ref": "#/definitions/AwsConfig",
          "description": "AWS Secrets Manager configuration (aws-secrets-manager backing store)"
        },
        "secrets": {
          "$ref": "#/definitions/Secrets",
          "description": "The dictionary of secrets to be uploaded"
        }
      },
      "required": [
        "version",
        "secrets"
      ],
      "title": "Values Secrets V3 Format"
    },
    "Settings": {
      "type": "object",
      "description": "Global settings for the secrets configuration",
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "array",
          "description": "Default target prefixes for secrets",
          "items": {
            "type": "string"
          },
          "default": ["hub"]
        },
        "namespace": {
          "type": "string",
          "description": "Namespace for kubernetes secrets",
          "default": "validated-patterns-secrets"
        }
      }
    },
    "Policies": {
      "type": "object",
      "description": "Password generation policies",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/SimplifiedPolicy"
          },
          {
            "type": "string",
            "description": "Raw vault policy format"
          }
        ]
      }
    },
    "SimplifiedPolicy": {
      "type": "object",
      "description": "Simplified policy configuration",
      "additionalProperties": false,
      "properties": {
        "length": {
          "type": "integer",
          "description": "Password length",
          "minimum": 1,
          "default": 16
        },
        "charset": {
          "type": "string",
          "description": "Character set to use",
          "enum": ["alphanumeric", "alphanumeric_symbols", "all"],
          "default": "alphanumeric"
        }
      }
    },
    "Secrets": {
      "type": "object",
      "description": "Dictionary of secrets to be uploaded",
      "additionalProperties": {
        "$ref": "#/definitions/Secret"
      }
    },
    "Secret": {
      "type": "object",
      "description": "A single secret configuration",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/FieldInstruction"
          },
          {
            "type": "array",
            "description": "Target list for this secret",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "properties": {
        "targets": {
          "type": "array",
          "description": "Target prefixes for this secret (vault backing store)",
          "items": {
            "type": "string"
          }
        },
        "namespaces": {
          "oneOf": [
            {
              "type": "string",
              "description": "Single namespace for this secret (kubernetes backing store)"
            },
            {
              "type": "array",
              "description": "Multiple namespaces for this secret (kubernetes backing store)",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "type": {
          "type": "string",
          "description": "Kubernetes secret type (kubernetes backing store)",
          "default": "Opaque"
        },
        "labels": {
          "type": "object",
          "description": "Labels for the kubernetes secret (kubernetes backing store)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the kubernetes secret (kubernetes backing store)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "secretName": {
          "type": "string",
          "description": "Custom secret name (aws-secrets-manager backing store)"
        },
        "description": {
          "type": "string",
          "description": "Secret description (aws-secrets-manager backing store)"
        },
        "kmsKeyId": {
          "type": "string",
          "description": "KMS key ID for encryption (aws-secrets-manager backing store)"
        },
        "tags": {
          "type": "object",
          "description": "Tags for the AWS secret (aws-secrets-manager backing store)",
          "additionalProperties": {
            "type": "string"
          }
        },
        "automaticRotation": {
          "$ref": "#/definitions/AwsAutomaticRotation",
          "description": "Automatic rotation configuration (aws-secrets-manager backing store)"
        }
      }
    },
    "FieldInstruction": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^file://.*",
          "description": "File path instruction: file://path/to/file"
        },
        {
          "type": "string",
          "pattern": "^file\\+base64://.*",
          "description": "Base64-encoded file instruction: file+base64://path/to/file"
        },
        {
          "type": "string",
          "pattern": "^ini://.*",
          "description": "INI file instruction: ini://path/to/file:section:key or ini://path/to/file:key"
        },
        {
          "type": "string",
          "pattern": "^generate:.*",
          "description": "Password generation instruction: generate:policy_name"
        },
        {
          "type": "string",
          "pattern": "^prompt:.*",
          "description": "User prompt instruction: prompt:message"
        },
        {
          "type": "string",
          "description": "Static value"
        },
        {
          "type": "number",
          "description": "Static numeric value"
        },
        {
          "type": "boolean",
          "description": "Static boolean value"
        }
      ]
    },
    "AwsConfig": {
      "type": "object",
      "description": "AWS Secrets Manager configuration",
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string",
          "description": "AWS region"
        },
        "profile": {
          "type": "string",
          "description": "AWS CLI profile to use"
        },
        "prefix": {
          "type": "string",
          "description": "Prefix for secret names"
        },
        "defaultKmsKeyId": {
          "type": "string",
          "description": "Default KMS key ID for encryption"
        },
        "defaultTags": {
          "type": "object",
          "description": "Default tags applied to all secrets",
          "additionalProperties": {
            "type": "string"
          }
        },
        "replicationRegions": {
          "type": "array",
          "description": "Regions for cross-region replication",
          "items": {
            "$ref": "#/definitions/AwsReplicationRegion"
          }
        }
      }
    },
    "AwsReplicationRegion": {
      "type": "object",
      "description": "AWS replication region configuration",
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string",
          "description": "Target region for replication"
        },
        "kmsKeyId": {
          "type": "string",
          "description": "KMS key ID for encryption in target region"
        }
      },
      "required": ["region"]
    },
    "AwsAutomaticRotation": {
      "type": "object",
      "description": "AWS Secrets Manager automatic rotation configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable automatic rotation"
        },
        "rotationLambdaArn": {
          "type": "string",
          "description": "ARN of the Lambda function for rotation"
        },
        "rotationSchedule": {
          "type": "string",
          "description": "Rotation schedule expression"
        }
      },
      "required": ["enabled"]
    }
  }
}